<web-app xmlns="http://xmlns.jcp.org/xml/ns/javaee" version="3.1">

    <!-- ✅ Page d'accueil par défaut : corrige le 404 quand on fait "Run" sur le projet
         (sans elle, Tomcat ne sait pas quoi servir pour "/") -->
    <welcome-file-list>
        <welcome-file>auth.jsp</welcome-file>
    </welcome-file-list>

    <servlet>
        <servlet-name>login</servlet-name>
        <servlet-class>controller.LoginServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>login</servlet-name>
        <url-pattern>/login</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>register</servlet-name>
        <servlet-class>controller.RegisterServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>register</servlet-name>
        <url-pattern>/register</url-pattern>
    </servlet-mapping>


    <!-- ✅ multipart-config ajouté pour que getPart() fonctionne -->
    <servlet>
        <servlet-name>UploadServlet</servlet-name>
        <servlet-class>controller.UploadServlet</servlet-class>
        <multipart-config>
            <max-file-size>52428800</max-file-size>       <!-- 50 MB par fichier -->
            <max-request-size>104857600</max-request-size> <!-- 100 MB total -->
            <file-size-threshold>1048576</file-size-threshold> <!-- 1 MB en mémoire avant écriture disque -->
        </multipart-config>
    </servlet>
    <servlet-mapping>
        <servlet-name>UploadServlet</servlet-name>
        <url-pattern>/UploadServlet</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>AnalyseServlet</servlet-name>
        <servlet-class>controller.AnalyseServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>AnalyseServlet</servlet-name>
        <url-pattern>/AnalyseServlet</url-pattern>
    </servlet-mapping>


    <servlet>
        <servlet-name>logout</servlet-name>
        <servlet-class>controller.LogoutServlet</servlet-class>
    </servlet>
    <servlet-mapping>
        <servlet-name>logout</servlet-name>
        <url-pattern>/LogoutServlet</url-pattern>
    </servlet-mapping>

</web-app>